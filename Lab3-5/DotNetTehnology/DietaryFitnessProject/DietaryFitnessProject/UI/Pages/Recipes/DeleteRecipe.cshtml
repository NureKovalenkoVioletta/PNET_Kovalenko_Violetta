@page "/Recipes/Delete/{id:int}"
@model DietaryFitnessProject.UI.Pages.Recipes.DeleteRecipeModel
@{
    ViewData["Title"] = "Видалення рецепту";
}

<div class="page-card">
    <h1 class="page-title">Видалити рецепт?</h1>
    <p class="page-lead">
        Буде видалено запис <strong>@Model.Recipe?.RecipeName</strong>. Зв’язки з прийомами їжі та інгредієнтами також будуть прибрані.
    </p>

    <form method="post" class="profile-form__actions">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn--danger">Так, видалити</button>
        <a class="btn btn--ghost" href="@Url.Content("~/Recipes")">Ні, повернутися</a>
    </form>
</div>
