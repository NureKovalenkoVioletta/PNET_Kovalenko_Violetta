@page "/Profile"
@model DietaryFitnessProject.UI.Pages.ProfileModel
@using DietaryFitnessProject.UI.Localization
@{
    ViewData["Title"] = "Мій профіль";
}

<div class="page-card page-card--wide">
    <h1 class="page-title">Мій профіль</h1>

    @if (Model.IsEditMode)
    {
        <p class="page-lead">
            Внесіть зміни та натисніть «Зберегти профіль». «Скасувати» поверне до перегляду без збереження.
        </p>

        <form method="post" class="form-stack profile-form profile-form--edit" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="form-field">
                <label asp-for="Input.FirstName"></label>
                <input asp-for="Input.FirstName" autocomplete="given-name" />
                <span asp-validation-for="Input.FirstName" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.LastName"></label>
                <input asp-for="Input.LastName" autocomplete="family-name" />
                <span asp-validation-for="Input.LastName" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.Gender"></label>
                <select asp-for="Input.Gender" asp-items="Model.GenderOptions"></select>
                <span asp-validation-for="Input.Gender" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.Age"></label>
                <input asp-for="Input.Age" />
                <span asp-validation-for="Input.Age" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.Height"></label>
                <input asp-for="Input.Height" />
                <span asp-validation-for="Input.Height" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.Weight"></label>
                <input asp-for="Input.Weight" />
                <span asp-validation-for="Input.Weight" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.ActivityLevel"></label>
                <select asp-for="Input.ActivityLevel" asp-items="Model.ActivityLevelOptions"></select>
                <span asp-validation-for="Input.ActivityLevel" class="field-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.Goal"></label>
                <select asp-for="Input.Goal" asp-items="Model.GoalOptions"></select>
                <span asp-validation-for="Input.Goal" class="field-error"></span>
            </div>

            <div class="profile-form__actions">
                <button type="submit" class="btn btn--primary">Зберегти профіль</button>
                <a class="btn btn--ghost" href="@Url.Content("~/Profile")">Скасувати</a>
            </div>
        </form>
    }
    else
    {
        <p class="page-lead">
            Дані профілю лише для перегляду. Щоб змінити їх, перейдіть у режим редагування.
        </p>

        <dl class="profile-readonly">
            <div class="profile-readonly__row">
                <dt>@Html.DisplayNameFor(m => m.Input.FirstName)</dt>
                <dd>@Model.Input.FirstName</dd>
            </div>
            <div class="profile-readonly__row">
                <dt>@Html.DisplayNameFor(m => m.Input.LastName)</dt>
                <dd>@Model.Input.LastName</dd>
            </div>
            <div class="profile-readonly__row">
                <dt>@Html.DisplayNameFor(m => m.Input.Email)</dt>
                <dd>@Model.Input.Email</dd>
            </div>
            <div class="profile-readonly__row">
                <dt>@Html.DisplayNameFor(m => m.Input.Gender)</dt>
                <dd>@UkFormOptions.GenderLabel(Model.Input.Gender)</dd>
            </div>
            <div class="profile-readonly__row">
                <dt>@Html.DisplayNameFor(m => m.Input.Age)</dt>
                <dd>@Model.Input.Age</dd>
            </div>
            <div class="profile-readonly__row">
                <dt>@Html.DisplayNameFor(m => m.Input.Height)</dt>
                <dd>@Model.Input.Height</dd>
            </div>
            <div class="profile-readonly__row">
                <dt>@Html.DisplayNameFor(m => m.Input.Weight)</dt>
                <dd>@Model.Input.Weight</dd>
            </div>
            <div class="profile-readonly__row">
                <dt>@Html.DisplayNameFor(m => m.Input.ActivityLevel)</dt>
                <dd>@UkFormOptions.ActivityLevelLabel(Model.Input.ActivityLevel)</dd>
            </div>
            <div class="profile-readonly__row">
                <dt>@Html.DisplayNameFor(m => m.Input.Goal)</dt>
                <dd>@UkFormOptions.GoalTypeLabel(Model.Input.Goal)</dd>
            </div>
        </dl>

        <div class="profile-form__actions">
            <a class="btn btn--primary" href="@Url.Content("~/Profile")?handler=Edit">Змінити профіль</a>
        </div>
    }
</div>

@section Scripts {
    @if (Model.IsEditMode)
    {
        <partial name="Shared/_ValidationScriptsPartial" />
    }
}
