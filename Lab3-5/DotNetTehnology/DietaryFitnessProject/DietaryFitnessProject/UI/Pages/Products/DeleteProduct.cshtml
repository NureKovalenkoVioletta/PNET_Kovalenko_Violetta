@page "/Products/Delete/{id:int}"
@model DietaryFitnessProject.UI.Pages.Products.DeleteProductModel
@{
    ViewData["Title"] = "Видалення продукту";
}

<div class="page-card">
    <h1 class="page-title">Видалити продукт?</h1>
    @if (Model.IsUsedInRecipes)
    {
        <p class="page-lead validation-summary-errors" style="margin-bottom:1rem;">
            Неможливо видалити продукт <strong>@Model.Product?.ProductName</strong>: він входить до складу одного або кількох рецептів.
            Спочатку приберіть продукт із рецептів.
        </p>
    }
    else
    {
        <p class="page-lead">
            Буде видалено запис <strong>@Model.Product?.ProductName</strong>.
        </p>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <form method="post" class="profile-form__actions">
        <input type="hidden" asp-for="Id" />
        @if (!Model.IsUsedInRecipes)
        {
            <button type="submit" class="btn btn--danger">Так, видалити</button>
        }
        <a class="btn btn--ghost" href="@Url.Content("~/Products")">@((Model.IsUsedInRecipes) ? "Повернутися" : "Ні, повернутися")</a>
    </form>
</div>
