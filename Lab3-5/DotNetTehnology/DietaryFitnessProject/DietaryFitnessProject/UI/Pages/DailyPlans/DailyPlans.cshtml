@page "/DailyPlans"
@model DietaryFitnessProject.UI.Pages.DailyPlans.DailyPlansModel
@{
    ViewData["Title"] = "Денні плани";
}

<div class="page-card page-card--wide">
    <h1 class="page-title">Денні плани</h1>
    <p class="page-lead">Список збережених денних планів. Деталі, цілі КБЖВ і генерація прийомів їжі — на сторінці «План на день».</p>

    <p class="toolbar">
        <a class="btn btn--primary" href="@Model.PlanDayPageUrl">
            @(Model.HasPlanForToday ? "Згенерувати план на інші дні" : "Згенерувати план на сьогодні")
        </a>
    </p>

    @if (Model.Plans.Count == 0)
    {
        <p class="empty-state">Планів ще немає. Створіть план на обрану дату.</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th class="num">ккал</th>
                        <th class="num">Білки, г</th>
                        <th class="num">Жири, г</th>
                        <th class="num">Вуглеводи, г</th>
                        <th class="num">Прийомів</th>
                        <th class="actions">Дії</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Plans)
                {
                    <tr>
                        <td>@p.DailyPlanDay.ToString("yyyy-MM-dd")</td>
                        <td class="num">@p.DailyPlanCalories.ToString("0.##")</td>
                        <td class="num">@p.DailyPlanProteins.ToString("0.##")</td>
                        <td class="num">@p.DailyPlanFats.ToString("0.##")</td>
                        <td class="num">@p.DailyPlanCarbs.ToString("0.##")</td>
                        <td class="num">@p.DailyPlanNumberOfMeals</td>
                        <td class="actions">
                            <a class="link-action" href="@Url.Content($"~/DailyPlans/Plan?date={p.DailyPlanDay:yyyy-MM-dd}")">Перейти до деталей</a>
                            <span class="sep">|</span>
                            <a class="link-action link-action--danger" href="@Url.Content($"~/DailyPlans/Delete/{p.DailyDietPlanId}")">Видалити</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
