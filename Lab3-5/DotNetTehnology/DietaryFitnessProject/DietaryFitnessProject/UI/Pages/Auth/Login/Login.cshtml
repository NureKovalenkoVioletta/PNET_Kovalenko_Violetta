@page "/Auth/Login"
@model DietaryFitnessProject.UI.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Вхід";
}

<div class="page-card">
    <h1 class="page-title">Вхід</h1>
    <p class="page-lead">Увійдіть за електронною поштою та паролем.</p>

    <form method="post" class="form-stack" novalidate>
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-field">
            <label asp-for="Input.Email"></label>
            <input asp-for="Input.Email" autocomplete="email" />
            <span asp-validation-for="Input.Email" class="field-error"></span>
        </div>
        <div class="form-field">
            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" autocomplete="current-password" />
            <span asp-validation-for="Input.Password" class="field-error"></span>
        </div>

        <button type="submit" class="btn btn--primary">Увійти</button>
    </form>

    <p class="form-footer">
        Немає облікового запису?
        <a href="@Url.Content("~/Auth/Register")">Зареєструватися</a>
    </p>
</div>

@section Scripts {
    <partial name="Shared/_ValidationScriptsPartial" />
}
